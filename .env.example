# Copy this file to ".env" and fill in real values.
# ".env" is git-ignored and must NEVER be committed.

# --- MongoDB ---
# Atlas connection string. Create a fresh DB user and use its credentials here.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/wtc_db?retryWrites=true&w=majority
MONGODB_DATABASE=wtc_db

# --- Auth ---
# Long random string used to sign JWTs. Generate one, e.g.:
#   openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret

# --- Google Sign-In (optional) ---
# OAuth 2.0 "Web application" client ID, used as the expected audience when verifying the
# Google ID token sent by the app. Leave unset to disable "Continue with Google".
# GOOGLE_CLIENT_ID=
