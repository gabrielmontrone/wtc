# Copy this file to ".env" and fill in real values.
# ".env" is git-ignored and must NEVER be committed.

# --- MongoDB ---
# Atlas connection string. Create a fresh DB user and use its credentials here.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/wtc_db?retryWrites=true&w=majority
MONGODB_DATABASE=wtc_db

# --- Auth ---
# Long random string used to sign JWTs. Generate one, e.g.:
#   openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret

# --- S3 / MinIO (object storage for attachments) ---
AWS_ACCESS_KEY=minioadmin
AWS_SECRET_KEY=minioadmin
AWS_S3_ENDPOINT=http://localhost:9000
AWS_S3_BUCKET=wtc-attachments
